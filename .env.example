# Exchange Config
EXCHANGE=binance
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Trading Config
SYMBOL=BTC/USDT
TIMEFRAME=5m
TRADE_AMOUNT_USDT=50

# Risk Management
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04
MAX_DAILY_LOSS_PCT=0.05

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Mode: paper or live
TRADING_MODE=paper
